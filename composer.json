{
  "name": "wpdesk/wpdesk-external-integration",
  "description": "",
  "type": "project",
  "license": "proprietary",
  "config": {
    "allow-plugins": {
      "ocramius/package-versions": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "gitlab-domains": [
      "gitlab.wpdesk.dev"
    ]
  },
  "require": {
    "php": ">=7.4",
    "wpdesk/wp-wpdesk-license": "^4.1.0",
    "psr/log": "^1.1"
  },
  "require-dev": {
    "humbug/php-scoper": "0.18.9",
    "sniccowp/php-scoper-wordpress-excludes": "^6.9",
    "wpdesk/php-scoper-woocommerce-excludes": "^9.3"
  },
  "autoload": {
    "classmap": [
      "src"
    ],
    "psr-4": {
      "WPDesk\\ExternalScripts\\": "scripts/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "post-create-project-cmd": "WPDesk\\ExternalScripts\\BuilderScript::postCreateProject"
  },
	"repositories": {
		"wpdesk": {
			"type": "composer",
			"url": "https://gitlab.wpdesk.dev/api/v4/group/wpdesk/-/packages/composer/"
		}
	}
}
