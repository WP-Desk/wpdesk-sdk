{
  "name": "wpdesk/wpdesk-external-integration",
  "description": "",
  "type": "project",
  "config": {
    "vendor-dir": "wpdesk-integration-vendor",
    "allow-plugins": {
      "ocramius/package-versions": true
    }
  },
  "require": {
    "php": ">=7.2"
  },
  "require-dev": {
    "wpdesk/wp-plugin-flow": "^3.2.0",
    "humbug/php-scoper": "0.12.3",
    "wpdesk/wp-logs": "^1.10.0"
  },
  "autoload": {
    "psr-4": {
      "WPDesk\\ExternalScripts\\": "scripts/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "post-create-project-cmd": [
      "WPDesk\\ExternalScripts\\BuilderScript::build_env",
      "rm -rf ./wpdesk-integration",
      "cp -f ./Reflector.php wpdesk-integration-vendor/humbug/php-scoper/src",
      "./wpdesk-integration-vendor/bin/php-scoper add-prefix --output-dir=./wpdesk-integration -f",
      "cp -f ./composer-integration.json wpdesk-integration/composer.json",
      "composer install -d wpdesk-integration",
      "composer dump -d wpdesk-integration -o",
      "rm -rf ./wpdesk-integration/composer.json ./wpdesk-integration/composer.lock",
      "WPDesk\\ExternalScripts\\BuilderScript::copy_to_plugin",
      "WPDesk\\ExternalScripts\\BuilderScript::info"
    ]
  }
}
